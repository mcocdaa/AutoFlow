# ============================================
# AutoFlow 环境配置模板
# 复制此文件为 .env 并根据需要修改
# ============================================

# --------------------------------------------
# 运行环境
# --------------------------------------------
# development: 开发环境（本地/dev Docker）
# production:  生产环境（Docker Swarm）
ENVIRONMENT=development

# --------------------------------------------
# 基础配置
# --------------------------------------------
CONTAINER_PREFIX=autoflow
LOG_LEVEL=INFO
API_VERSION=v1

# 后端监听地址（本地模式使用）
HOST=0.0.0.0
# 数据存储目录（本地模式使用）
DATA_DIR=./backend/data
# CORS 允许来源
CORS_ORIGINS=*

# --------------------------------------------
# 端口配置
# --------------------------------------------
# 后端（Docker 模式）: 内部 3000，主机暴露端口
BACKEND_INTERNAL_PORT=3000
BACKEND_EXTERNAL_PORT=3001

# 前端（Docker 模式）: 内部 8000，主机暴露端口
FRONTEND_INTERNAL_PORT=8000
FRONTEND_EXTERNAL_PORT=8001

# 前端本地开发端口（local 模式 npm run dev 使用）
FRONTEND_DEV_PORT=5181

# 数据库（设为 true 时将 MySQL 端口暴露到主机）
EXPOSE_DB_PORT=false
DB_EXTERNAL_PORT=3306

# Redis（设为 true 时将 Redis 端口暴露到主机）
EXPOSE_REDIS_PORT=false
REDIS_EXTERNAL_PORT=6379

# --------------------------------------------
# 密码 / 密钥（运行 scripts/init-secrets.sh 写入 secrets/ 目录）
# 生产环境请使用强随机密码
# --------------------------------------------
DB_PASSWORD=change_me_db_password
MYSQL_ROOT_PASSWORD=change_me_root_password
# 用于 JWT/session 签名，建议 openssl rand -hex 32 生成
SECRET_KEY=change_me_secret_key

# secrets 后备模式（backend 读取密码的方式）
# file: 从 /run/secrets/* 文件读取（Docker secrets）
# env:  从环境变量 DB_PASSWORD / SECRET_KEY 直接读取
SECRET_FALLBACK_MODE=file

# --------------------------------------------
# 数据库配置
# --------------------------------------------
# Docker 模式用容器名: mysql
# 本地模式用: localhost
DB_HOST=mysql
DB_PORT=3306
DB_USER=autoflow
DB_NAME=autoflow_db

# --------------------------------------------
# Redis 配置
# --------------------------------------------
# Docker 模式用容器名: redis
# 本地模式用: localhost
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --------------------------------------------
# 前端配置
# --------------------------------------------
# 浏览器访问后端的地址
# 本地模式: http://localhost:3001
# Docker 模式由 docker-compose 内部覆盖为 http://autoflow-backend:3000
VITE_API_URL=http://localhost:3001

# 前端 Docker 构建模式
# web:        启动 Vite dev server（开发/演示）
# build-only: 仅构建静态文件（CI 用）
FRONTEND_BUILD_MODE=web

# 以纯 Web 模式运行，跳过 Electron（本地开发和 Docker 均需设为 true）
# 设为 false 或删除 → 启动 Electron 桌面窗口（需要图形环境）
DOCKER_WEB=true
