# ===================== 通用配置 =====================
# 容器名前缀（统一管理所有容器名）
CONTAINER_PREFIX=autoflow
# 网络名（和.devcontainer保持一致）
NETWORK_NAME=autoflow_default

# ===================== 数据库配置 =====================
# 宿主机访问地址（本地调试用）
DB_HOST=localhost
# 宿主机映射端口
DB_PORT=3306
# 数据库账号/密码（敏感）
DB_USER=autoflow
DB_PASSWORD=autoflow_secret
# 数据库名
DB_NAME=autoflow_db
# MySQL root 密码（敏感）
MYSQL_ROOT_PASSWORD=root_password

# ===================== Redis 配置 =====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Redis 密码（若需开启，取消注释并填写）
# REDIS_PASSWORD=your_redis_password

# ===================== InfluxDB 配置 =====================
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
# 初始化配置（敏感）
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=password123
INFLUXDB_INIT_ORG=autoflow
INFLUXDB_INIT_BUCKET=autoflow_logs
# 认证 Token（敏感）
INFLUXDB_TOKEN=my-super-secret-auth-token

# ===================== MinIO 配置 =====================
MINIO_HOST=localhost
# 存储服务端口
MINIO_PORT=9000
# 控制台端口
MINIO_CONSOLE_PORT=9001
# MinIO 密钥（敏感）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ===================== 应用配置 =====================
APP_ENV=development
# 应用密钥（敏感，务必替换为随机字符串）
SECRET_KEY=change_this_to_a_secure_random_string
LOG_LEVEL=INFO

# ===================== 引申配置 =====================
COMPOSE_PROJECT_NAME=${CONTAINER_PREFIX}-backend
