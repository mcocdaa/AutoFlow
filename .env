# ============================================
# AutoFlow 环境配置（开发环境默认值）
# ============================================

# --------------------------------------------
# 运行环境
# --------------------------------------------
ENVIRONMENT=development

# --------------------------------------------
# 基础配置
# --------------------------------------------
CONTAINER_PREFIX=autoflow
LOG_LEVEL=INFO
API_VERSION=v1
HOST=0.0.0.0
DATA_DIR=./backend/data
CORS_ORIGINS=*

# --------------------------------------------
# 端口配置
# --------------------------------------------
BACKEND_INTERNAL_PORT=3000
BACKEND_EXTERNAL_PORT=3001

FRONTEND_INTERNAL_PORT=8000
FRONTEND_EXTERNAL_PORT=8001
FRONTEND_DEV_PORT=8001

EXPOSE_DB_PORT=false
DB_EXTERNAL_PORT=3306

EXPOSE_REDIS_PORT=false
REDIS_EXTERNAL_PORT=6379

# --------------------------------------------
# 密码 / 密钥
# 修改后运行 scripts/init-secrets.sh 同步到 secrets/ 目录
# --------------------------------------------
DB_PASSWORD=change_me_db_password
MYSQL_ROOT_PASSWORD=change_me_root_password
SECRET_KEY=change_me_secret_key

# secrets 后备模式: file（Docker secrets）| env（直接读环境变量）
SECRET_FALLBACK_MODE=file

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_USER=autoflow
DB_NAME=autoflow_db

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --------------------------------------------
# 前端配置
# --------------------------------------------
VITE_API_URL=http://localhost:3001
FRONTEND_BUILD_MODE=web

# 以纯 Web 模式运行（跳过 Electron，适合本地开发和 Docker）
# false 或删除此行 → 启动 Electron 桌面窗口（需要图形环境）
DOCKER_WEB=true
