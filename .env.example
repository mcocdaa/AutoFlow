# ===================== 通用配置 =====================
# 容器名前缀（统一管理所有容器名）
CONTAINER_PREFIX=autoflow
# 网络名（和.devcontainer保持一致）
NETWORK_NAME=autoflow_default
# 日志级别
LOG_LEVEL=INFO # INFO, DEBUG, WARN, ERROR, FATAL
# 构建环境
BUILD_ENV=dev # dev or prod

# 敏感变量（DB_PASSWORD、SECRET_KEY 等）不要写入 .env；请使用 secrets/*.key 并执行 bash ./build.sh dev
