# ============================================
# AutoFlow 环境配置
# ============================================

# --------------------------------------------
# 运行环境
# --------------------------------------------
# development: 开发环境（本地运行）
# production: 生产环境（Docker 部署）
ENVIRONMENT=development

# --------------------------------------------
# Docker 端口配置
# --------------------------------------------
BACKEND_EXTERNAL_PORT=3001
FRONTEND_EXTERNAL_PORT=8001

# --------------------------------------------
# 后端配置
# --------------------------------------------
HOST=0.0.0.0
PORT=3000
API_VERSION=v1
DATA_DIR=./backend/data
LOG_LEVEL=INFO

# CORS 配置
CORS_ORIGINS=*

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_USER=autoflow
DB_NAME=autoflow_db

# Redis 配置
REDIS_DB=0

# --------------------------------------------
# 前端配置
# --------------------------------------------
# 本地开发时使用 BACKEND_EXTERNAL_PORT (3001)
# Docker 部署时由 docker-compose.yml 覆盖为 autoflow-backend:3000
VITE_API_URL=http://localhost:3001

# 前端构建模式
# web: 启动 Web 开发服务器（演示/测试）
# build-only: 仅构建输出静态文件（CI用）
FRONTEND_BUILD_MODE=web
