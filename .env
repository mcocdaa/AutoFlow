# ============================================
# AutoFlow 环境配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# ---------------- 基础配置 ----------------
CONTAINER_PREFIX=autoflow
NETWORK_NAME=autoflow_default
LOG_LEVEL=INFO

# ---------------- 端口配置 ----------------
# 后端: 内部 3000，外部 3001
BACKEND_INTERNAL_PORT=3000
BACKEND_EXTERNAL_PORT=3003

# 前端: 内部 8000，外部 8001
FRONTEND_INTERNAL_PORT=8000
FRONTEND_EXTERNAL_PORT=8003

# 数据库: 默认不暴露（设置为 true 时暴露）
EXPOSE_DB_PORT=false
DB_EXTERNAL_PORT=3306

# Redis: 默认不暴露（设置为 true 时暴露）
EXPOSE_REDIS_PORT=false
REDIS_EXTERNAL_PORT=6379

# ---------------- 数据库配置 ----------------
DB_HOST=mysql
DB_PORT=3306
DB_USER=autoflow
DB_NAME=autoflow_db

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------------- 前端 API 配置 ----------------
# 前端访问后端的地址（浏览器视角）
VITE_API_URL=http://localhost:3003/api/v1

# ---------------- 前端构建模式 ----------------
# web: 启动 Web 开发服务器（演示/测试）
# build-only: 仅构建输出静态文件（CI用）
FRONTEND_BUILD_MODE=web
