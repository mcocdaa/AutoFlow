# ==================== 外部可配置项 ====================
# 用户可修改的配置（Docker 映射到宿主机的端口）

# 项目名称
COMPOSE_PROJECT_NAME=autoflow

# 版本配置
APP_VERSION=0.1.0
API_VERSION=v1

# 外部端口（从宿主机访问的端口）
BACKEND_PORT=8000
DB_PORT_OUTER=3306
REDIS_PORT_OUTER=6379

# 日志级别
LOG_LEVEL=INFO

# 数据库配置
DB_USER=autoflow
DB_NAME=autoflow_db

# Redis 配置
REDIS_DB=0

# 静态文件服务（前后端分离部署时设为 false）
SERVE_STATIC_FILES=false
STATIC_FILES_DIR=/app/static

# 插件额外目录（多个目录用 : 分隔）
# AUTOFLOW_PLUGIN_DIRS=/path/to/plugins1:/path/to/plugins2
